# LOCAL DEVELOPMENT ONLY. Copy this file to .env and change credentials if needed.
# Never reuse these values in shared, staging, or production environments.
# Host ports are bound to 127.0.0.1 by compose.yaml. Containers communicate by
# fixed Compose service names and container ports documented in the local guide.

# API listener (loopback by default; set API_HOST=0.0.0.0 only when intentionally exposed)
API_HOST=127.0.0.1
# API_PORT overrides a platform-provided PORT when both are set.
# Render supplies PORT automatically, so leave API_PORT unset there to use the platform value.
API_PORT=3000
API_CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
ASSESSMENT_TIMEOUT_MS=30000

# Synthetic hackathon demo identity. These stable public UUIDs contain no credentials or real data.
# The VITE values must match the IDs inserted by `pnpm demo:seed`.
DEMO_TENANT_ID=8f7e6d5c-4b3a-4210-9fed-cba987654321
DEMO_USER_ID=719e2bb4-0a4e-4f04-9fd1-d7261ed71f11
DEMO_MEMBERSHIP_ID=b3294a61-3ef0-46c4-9231-773ba0f39f67
VITE_API_BASE_URL=http://127.0.0.1:3000
VITE_DEMO_TENANT_ID=8f7e6d5c-4b3a-4210-9fed-cba987654321
VITE_DEMO_USER_ID=719e2bb4-0a4e-4f04-9fd1-d7261ed71f11

# Managed PostgreSQL URL. A non-empty value takes precedence over the local fields below.
# Use the Render Postgres internal connection URL in the API service; never expose it to Vite.
APP_POSTGRES_URL=

# Local Docker PostgreSQL fallback (host clients use 127.0.0.1:APP_POSTGRES_PORT)
APP_POSTGRES_PORT=5432
APP_POSTGRES_USER=opsguard_app
APP_POSTGRES_PASSWORD=opsguard_app_local_2026
APP_POSTGRES_DATABASE=opsguard_app_dev

# Temporal persistence PostgreSQL (isolated container and volume)
TEMPORAL_POSTGRES_PORT=5433
TEMPORAL_POSTGRES_USER=opsguard_temporal
TEMPORAL_POSTGRES_PASSWORD=opsguard_temporal_local_2026
TEMPORAL_POSTGRES_ADMIN_DATABASE=opsguard_temporal_admin

# Redis (host clients use 127.0.0.1:REDIS_PORT)
REDIS_PORT=6379
REDIS_PASSWORD=opsguard_redis_local_2026

# MinIO (API and console are host-facing; containers use minio:9000)
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ROOT_USER=opsguard_minio
MINIO_ROOT_PASSWORD=opsguard_minio_local_2026

# Temporal frontend and UI (containers use temporal:7233)
TEMPORAL_GRPC_PORT=7233
TEMPORAL_UI_PORT=8233

# OpenTelemetry Collector (host instrumentation uses these loopback ports)
OTEL_COLLECTOR_GRPC_PORT=4317
OTEL_COLLECTOR_HTTP_PORT=4318
OTEL_COLLECTOR_HEALTH_PORT=13133

# Jaeger query UI (collector export uses jaeger:4317 internally)
JAEGER_UI_PORT=16686

# OpenAI assessment adapter (required by API startup for the hackathon demo)
# Keep OPENAI_API_KEY in an ignored local .env or an approved secret manager. Never commit a key.
# Select an approved model explicitly; there is intentionally no model-specific default.
OPENAI_API_KEY=
OPENAI_MODEL=
RUN_OPENAI_INTEGRATION_TESTS=false

# Request-assessment evaluation pricing. Copy current approved provider rates into local .env.
# Rates are USD per one million tokens. The label records the pricing basis in each report.
EVAL_REQUEST_ASSESSMENT_PRICING_LABEL=
EVAL_REQUEST_ASSESSMENT_INPUT_USD_PER_MILLION_TOKENS=
EVAL_REQUEST_ASSESSMENT_OUTPUT_USD_PER_MILLION_TOKENS=
EVAL_REQUEST_ASSESSMENT_CACHED_INPUT_USD_PER_MILLION_TOKENS=
EVAL_REQUEST_ASSESSMENT_TIMEOUT_MS=30000
