{
  "name": "@opsguard/evaluation-cli",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "lint": "eslint src --max-warnings=0",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.test.json",
    "test": "vitest run --config ../../vitest.config.ts --root .",
    "build": "tsc -p tsconfig.json",
    "eval:request-assessment": "node --env-file-if-exists=../../.env dist/request-assessment-evaluation-cli.js"
  },
  "dependencies": {
    "@opsguard/ai-core": "workspace:*",
    "@opsguard/application": "workspace:*",
    "@opsguard/config": "workspace:*",
    "@opsguard/contracts": "workspace:*",
    "@opsguard/domain": "workspace:*",
    "@opsguard/testing": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "24.10.0"
  }
}
