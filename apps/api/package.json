{
  "name": "@opsguard/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "lint": "eslint src --max-warnings=0",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.test.json",
    "test": "vitest run --config ../../vitest.config.ts --root . --exclude src/**/*.integration.test.ts",
    "test:integration": "vitest run --config ../../vitest.config.ts --root . src/api.integration.test.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js"
  },
  "dependencies": {
    "@opsguard/application": "workspace:*",
    "@opsguard/auth": "workspace:*",
    "@opsguard/config": "workspace:*",
    "@opsguard/contracts": "workspace:*",
    "@opsguard/database": "workspace:*",
    "@opsguard/domain": "workspace:*",
    "@opsguard/observability": "workspace:*",
    "fastify": "^5.10.0"
  },
  "devDependencies": {
    "@types/node": "24.10.0",
    "@types/pg": "8.20.0",
    "dotenv": "17.4.2",
    "drizzle-orm": "0.45.2",
    "pg": "8.22.0"
  }
}
