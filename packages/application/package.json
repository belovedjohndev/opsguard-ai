{
  "name": "@opsguard/application",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.13.0"
  },
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "lint": "eslint src --max-warnings=0",
    "typecheck": "tsc -p tsconfig.build.json --noEmit && tsc -p tsconfig.test.json",
    "test": "vitest run --config ../../vitest.config.ts --root .",
    "build": "tsc -p tsconfig.build.json"
  },
  "dependencies": {
    "@opsguard/ai-core": "workspace:*",
    "@opsguard/contracts": "workspace:*",
    "@opsguard/domain": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "24.10.0"
  }
}
