{
  "name": "@opsguard/database",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.13.0"
  },
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "lint": "eslint src drizzle.config.ts --max-warnings=0",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.tooling.json",
    "test": "vitest run --config ../../vitest.config.ts --root .",
    "build": "tsc -p tsconfig.json",
    "db:generate": "drizzle-kit generate --name=initial_tenant_model",
    "db:migrate": "drizzle-kit migrate",
    "db:check": "drizzle-kit check"
  },
  "dependencies": {
    "dotenv": "17.4.2",
    "drizzle-orm": "0.45.2",
    "pg": "8.22.0"
  },
  "devDependencies": {
    "@types/node": "24.10.0",
    "@types/pg": "8.20.0",
    "drizzle-kit": "0.31.10",
    "tsx": "4.23.1"
  }
}
